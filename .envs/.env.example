ENVIRONMENT="local"
PROJECT_NAME="bank-fastapi"
PROJECT_DESCRIPTION="Welcome to the secure fastapi"
API_V1_STR="/api/v1"
SITE_NAME="BANKITO"
POSTGRES_USER=""
POSTGRES_PASSWORD="."
POSTGRES_DB=""
POSTGRES_HOST="postgres"
POSTGRES_PORT="5432"

# In-container connection (host = the compose service name, internal port 5432).
# External tools (psql/DBeaver) connect on localhost:5433 instead.
DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"
MAIL_FROM=""
MAIL_FROM_NAME=""

CELERY_BROKER_URL="amqp://rabbitmq"
CELERY_RESULT_BACKEND="redis://redis:6379/0"
CELERY_FLOWER_USER=""
CELERY_FLOWER_PASSWORD=""

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Required JWT signing secrets - the app refuses to start if they are empty.
# Generate each one with: openssl rand -hex 32
JWT_SECRET_KEY=""
SIGNING_KEY=""

# JSON list of allowed browser origins (leave empty to disable CORS).
CORS_ORIGINS='["http://localhost:3000"]'